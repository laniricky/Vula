# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild
.cxx/

# Google Services (firebase) - Keep this as it contains project config
# google-services.json

# Firebase emulator data (do not commit emulator state)
.firebase/
firestore-debug.log
firestore-export/
auth-export/
ui-debug.log
pubsub-debug.log
database-debug.log
hosting-debug.log
functions-debug.log
storage-debug.log
*-debug.log

# Mac/Linux
.DS_Store
Thumbs.db

# NDK
obj/
*.so

# Kotlin
*.kotlin_module
node_modules/

